FROM golang:1.26 AS builder
WORKDIR /workspace
COPY go.mod go.sum ./
RUN go mod download
COPY api/ api/
COPY internal/console/ internal/console/
COPY cmd/console/ cmd/console/
RUN CGO_ENABLED=0 go build -o console ./cmd/console/

FROM node:22-alpine AS frontend
WORKDIR /app
COPY web/package.json web/package-lock.json ./
RUN npm ci
COPY web/ .
RUN npx vite build

FROM gcr.io/distroless/static:nonroot
COPY --from=builder /workspace/console /console
COPY --from=frontend /app/dist /web
USER 65532:65532
ENTRYPOINT ["/console", "--web-dir=/web"]
