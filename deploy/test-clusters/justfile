# Multi-cluster test environment using k3d
# Simulates: management cluster + 2 workload clusters
# Usage: just --justfile deploy/test-clusters/justfile <recipe>

set dotenv-load := false

mgmt_cluster   := "agentops-mgmt"
prod_cluster   := "agentops-prod"
staging_cluster := "agentops-staging"
network        := "agentops-net"
release        := "agentops"
factory_release := "infra"
operator_image := "ghcr.io/samyn92/agentops/operator:dev"
console_image  := "ghcr.io/samyn92/agentops/console:dev"
runtime_image  := "ghcr.io/samyn92/agentops/runtime:dev"
gitlab_label_image := "ghcr.io/samyn92/agentops/channels/gitlab-label:dev"

# ── Lifecycle ─────────────────────────────────────────

# Create all clusters + shared network
up:
    #!/usr/bin/env bash
    set -euo pipefail
    echo "==> Creating shared Docker network..."
    docker network create {{network}} 2>/dev/null || true

    echo "==> Creating management cluster..."
    k3d cluster create {{mgmt_cluster}} \
      --config {{justfile_directory()}}/k3d-mgmt.yaml \
      --network {{network}}

    echo "==> Creating prod cluster..."
    k3d cluster create {{prod_cluster}} \
      --config {{justfile_directory()}}/k3d-workload.yaml \
      --network {{network}}

    echo "==> Creating staging cluster..."
    k3d cluster create {{staging_cluster}} \
      --config {{justfile_directory()}}/k3d-workload.yaml \
      --network {{network}}

    echo ""
    echo "==> Generating kubeconfigs for cross-cluster access..."
    just --justfile {{justfile()}} generate-kubeconfigs

    echo ""
    echo "=== Multi-cluster environment ready ==="
    echo "  mgmt:    kubectl --context k3d-{{mgmt_cluster}}"
    echo "  prod:    kubectl --context k3d-{{prod_cluster}}"
    echo "  staging: kubectl --context k3d-{{staging_cluster}}"
    echo ""
    echo "Next: just --justfile deploy/test-clusters/justfile deploy-platform"

# Tear down all clusters
down:
    k3d cluster delete {{mgmt_cluster}} 2>/dev/null || true
    k3d cluster delete {{prod_cluster}} 2>/dev/null || true
    k3d cluster delete {{staging_cluster}} 2>/dev/null || true
    docker network rm {{network}} 2>/dev/null || true
    @echo "All clusters removed."

# Show cluster status
status:
    @echo "=== Clusters ==="
    @k3d cluster list 2>/dev/null | grep agentops || echo "  (none running)"
    @echo ""
    @echo "=== Contexts ==="
    @kubectl config get-contexts 2>/dev/null | grep agentops || echo "  (none)"

# ── Kubeconfig Generation ─────────────────────────────

# Generate kubeconfigs that the mgmt cluster agents use to access workload clusters.
# These are injected as K8s Secrets in the mgmt cluster.
generate-kubeconfigs:
    #!/usr/bin/env bash
    set -euo pipefail
    mkdir -p {{justfile_directory()}}/generated

    for cluster in {{prod_cluster}} {{staging_cluster}}; do
      echo "  generating kubeconfig for $cluster..."
      # Get the kubeconfig with the internal docker-network server address
      k3d kubeconfig get "$cluster" | \
        sed "s|https://0.0.0.0:[0-9]*|https://k3d-${cluster}-server-0:6443|g" \
        > {{justfile_directory()}}/generated/${cluster}.kubeconfig
    done

    echo "  kubeconfigs written to deploy/test-clusters/generated/"

# Inject kubeconfigs as Secrets in the mgmt cluster (for observer agents)
inject-kubeconfigs:
    #!/usr/bin/env bash
    set -euo pipefail
    ctx="k3d-{{mgmt_cluster}}"

    kubectl --context "$ctx" create namespace agents 2>/dev/null || true

    for cluster in {{prod_cluster}} {{staging_cluster}}; do
      echo "  injecting kubeconfig for $cluster..."
      kubectl --context "$ctx" create secret generic "kubeconfig-${cluster}" \
        -n agents \
        --from-file=kubeconfig={{justfile_directory()}}/generated/${cluster}.kubeconfig \
        --dry-run=client -o yaml | kubectl --context "$ctx" apply -f -
    done

    echo "  done. Agents can now access workload clusters."

# ── Platform Deployment ───────────────────────────────

# Deploy AgentOps platform on the mgmt cluster.
deploy-platform: import-platform-images
    #!/usr/bin/env bash
    set -euo pipefail
    ctx="k3d-{{mgmt_cluster}}"
    echo "==> Installing CRDs on mgmt cluster..."
    kubectl --context "$ctx" apply -f {{justfile_directory()}}/../../config/crd/bases/

    echo "==> Creating namespaces..."
    kubectl --context "$ctx" create namespace agent-system 2>/dev/null || true
    kubectl --context "$ctx" create namespace agents 2>/dev/null || true

    echo "==> Installing AgentOps umbrella chart..."
    helm upgrade --install {{release}} {{justfile_directory()}}/../charts/agentops \
      -n agent-system --create-namespace \
      --kube-context "$ctx" \
      --skip-crds \
      --set createNamespace=false \
      --set agentops-operator.image.tag=dev \
      --set agentops-operator.image.pullPolicy=IfNotPresent \
      --set agentops-console.image.tag=dev \
      --set agentops-console.image.pullPolicy=IfNotPresent \
      --set agentops-console.console.webDir=/web \
      --set memory.image.tag=latest

    echo "==> Waiting for platform pods..."
    kubectl --context "$ctx" -n agent-system rollout status deploy/{{release}}-agentops-operator --timeout=180s || true
    kubectl --context "$ctx" -n agent-system rollout status deploy/{{release}}-agentops-console --timeout=180s || true
    kubectl --context "$ctx" -n agent-system get pods

# Build local images used by the E2E environment.
build-platform-images:
    docker build -t {{operator_image}} -f {{justfile_directory()}}/../../Dockerfile.operator {{justfile_directory()}}/../..
    docker build -t {{console_image}} -f {{justfile_directory()}}/../../Dockerfile.console {{justfile_directory()}}/../..
    docker build -t {{runtime_image}} -f {{justfile_directory()}}/../../Dockerfile.runtime {{justfile_directory()}}/../..
    docker build -t {{gitlab_label_image}} -f {{justfile_directory()}}/../../channels/gitlab-label/Dockerfile {{justfile_directory()}}/../..

# Import local images into the management k3d cluster.
import-platform-images: build-platform-images
    k3d image import {{operator_image}} -c {{mgmt_cluster}}
    k3d image import {{console_image}} -c {{mgmt_cluster}}
    k3d image import {{runtime_image}} -c {{mgmt_cluster}}
    k3d image import {{gitlab_label_image}} -c {{mgmt_cluster}}

# Port-forward the console UI to http://localhost:8080.
ui:
    kubectl --context k3d-{{mgmt_cluster}} -n agent-system port-forward svc/{{release}}-agentops-console 8080:80

# Create secrets required by the E2E factory.
# Requires: KIMI_API_KEY, GITLAB_PLANNER_TOKEN, GITLAB_CODER_TOKEN
prepare-secrets:
    #!/usr/bin/env bash
    set -euo pipefail
    ctx="k3d-{{mgmt_cluster}}"
    : "${KIMI_API_KEY:?set KIMI_API_KEY}"
    : "${GITLAB_PLANNER_TOKEN:?set GITLAB_PLANNER_TOKEN}"
    : "${GITLAB_CODER_TOKEN:?set GITLAB_CODER_TOKEN}"

    kubectl --context "$ctx" create namespace agents 2>/dev/null || true
    kubectl --context "$ctx" -n agents create secret generic llm-api-keys \
      --from-literal=KIMI_API_KEY="$KIMI_API_KEY" \
      --dry-run=client -o yaml | kubectl --context "$ctx" apply -f -
    kubectl --context "$ctx" -n agents create secret generic gitlab-bot-planner \
      --from-literal=token="$GITLAB_PLANNER_TOKEN" \
      --dry-run=client -o yaml | kubectl --context "$ctx" apply -f -
    kubectl --context "$ctx" -n agents create secret generic gitlab-bot-coder \
      --from-literal=token="$GITLAB_CODER_TOKEN" \
      --dry-run=client -o yaml | kubectl --context "$ctx" apply -f -
    echo "==> E2E secrets applied."

# Apply RBAC needed by the generated management-cluster observer.
deploy-observer-rbac:
    #!/usr/bin/env bash
    set -euo pipefail
    ctx="k3d-{{mgmt_cluster}}"
    kubectl --context "$ctx" apply -f {{justfile_directory()}}/observer-rbac.yaml

# Render the factory chart for local validation.
render-factory:
    helm template {{factory_release}} {{justfile_directory()}}/../charts/agent-factory \
      -n agents \
      -f {{justfile_directory()}}/factory-e2e-values.yaml

# Deploy the agent factory on the mgmt cluster
deploy-factory preset="devops-gitops":
    #!/usr/bin/env bash
    set -euo pipefail
    ctx="k3d-{{mgmt_cluster}}"
    echo "==> Deploying agent factory ({{preset}})..."
    helm upgrade --install {{factory_release}} {{justfile_directory()}}/../charts/agent-factory \
      -n agents --create-namespace \
      --kube-context "$ctx" \
      -f {{justfile_directory()}}/factory-e2e-values.yaml
    echo "==> Factory deployed. Check: kubectl --context $ctx get agents,channels,integrations -n agents"

# Simulate workload on prod/staging (deploy sample apps for agents to observe)
deploy-workloads:
    #!/usr/bin/env bash
    set -euo pipefail
    for cluster in {{prod_cluster}} {{staging_cluster}}; do
      ctx="k3d-${cluster}"
      echo "==> Deploying sample workloads on $cluster..."
      kubectl --context "$ctx" create namespace demo 2>/dev/null || true
      kubectl --context "$ctx" apply -f {{justfile_directory()}}/workloads/ -n demo
    done
    echo "==> Workloads deployed."

# Prepare the management-cluster observer E2E path.
# Does not create clusters; run `up` first.
e2e-setup: deploy-platform prepare-secrets inject-kubeconfigs deploy-observer-rbac deploy-factory deploy-workloads e2e-test verify

# Validate rendered manifests and the deployed E2E resources.
e2e-test:
    #!/usr/bin/env bash
    set -euo pipefail
    ctx="k3d-{{mgmt_cluster}}"
    tmp="$(mktemp)"
    trap 'rm -f "$tmp"' EXIT

    echo "==> Linting factory chart..."
    helm lint {{justfile_directory()}}/../charts/agent-factory \
      -f {{justfile_directory()}}/factory-e2e-values.yaml

    echo "==> Rendering factory chart..."
    helm template {{factory_release}} {{justfile_directory()}}/../charts/agent-factory \
      -n agents \
      -f {{justfile_directory()}}/factory-e2e-values.yaml > "$tmp"

    echo "==> Server-side validating manifests..."
    kubectl --context "$ctx" -n agents apply --dry-run=server -f "$tmp"

    echo "==> Checking generated observers..."
    kubectl --context "$ctx" -n agents get agent \
      {{factory_release}}-observer-mgmt \
      {{factory_release}}-observer-prod \
      {{factory_release}}-observer-staging

    echo "==> Waiting for observer deployments..."
    for name in {{factory_release}}-observer-mgmt {{factory_release}}-observer-prod {{factory_release}}-observer-staging; do
      kubectl --context "$ctx" -n agents rollout status "deploy/$name" --timeout=180s
    done

    echo "==> Waiting for channel deployments..."
    kubectl --context "$ctx" -n agents rollout status "deploy/{{factory_release}}-label-bridge" --timeout=180s

    echo "==> Checking kubeconfig secrets..."
    kubectl --context "$ctx" -n agents get secrets kubeconfig-{{prod_cluster}} kubeconfig-{{staging_cluster}}

    echo "==> E2E smoke test passed."

# Show the important E2E resources.
verify:
    #!/usr/bin/env bash
    set -euo pipefail
    ctx="k3d-{{mgmt_cluster}}"
    echo "==> AgentOps resources"
    kubectl --context "$ctx" -n agents get providers,integrations,agents,channels
    echo ""
    echo "==> Agent pods"
    kubectl --context "$ctx" -n agents get pods
    echo ""
    echo "==> Kubeconfig secrets for remote observers"
    kubectl --context "$ctx" -n agents get secrets kubeconfig-{{prod_cluster}} kubeconfig-{{staging_cluster}} 2>/dev/null || true

# ── Utilities ─────────────────────────────────────────

# Shell into the mgmt cluster context
mgmt-ctx:
    @kubectl config use-context k3d-{{mgmt_cluster}}
    @echo "Now using: k3d-{{mgmt_cluster}}"

# Shell into prod cluster context
prod-ctx:
    @kubectl config use-context k3d-{{prod_cluster}}
    @echo "Now using: k3d-{{prod_cluster}}"

# Shell into staging cluster context
staging-ctx:
    @kubectl config use-context k3d-{{staging_cluster}}
    @echo "Now using: k3d-{{staging_cluster}}"
